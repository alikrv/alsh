#!/usr/bin/env alsh

@stdlib
@main

function main() {
    echo "=== Simple Chain Test ==="
    
    # Direct chain expression evaluation
    let result = chain {
        "hello"
        std::upper()
    }
    println("result = $result")
    
    # Another test
    let len_result = chain {
        "hello world"
        std::split(@, " ")
        std::len()
    }
    println("len_result = $len_result")
}
