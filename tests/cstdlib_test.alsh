#!/usr/local/bin/alsh

# cstdlib_test.alsh
# comprehensive test of C standard library functions via c:: namespace
# some of these WILL crash if your FFI isnt handling types right, thats the point
# generated by Claude because I'm lazy


function test_stdio() {
    echo "--- stdio.h ---"

    # puts is the simplest, already known to work
    c::puts("puts: hello from C")

    # printf with various format specifiers
    let i = 42
    let f = 3.14
    let s = "world"
    c::printf("printf int: %d\n", i)
    c::printf("printf float: %f\n", f)
    c::printf("printf string: %s\n", s)
    c::printf("printf hex: %x\n", i)
    c::printf("printf octal: %o\n", i)
    c::printf("printf padded: %010d\n", i)
    c::printf("printf multiple: %d %.2f %s\n", i, f, s)

    # fprintf to stderr
    c::fprintf(2, "fprintf: this went to stderr\n")   # 2 = stderr fd... depends how you handle FILE*

    # putchar
    c::putchar(65)   # 'A'
    c::putchar(10)   # newline
}

function test_stdlib() {
    echo "--- stdlib.h ---"

    # atoi / atof
    let numstr = "1234"
    let floatstr = "2.718"
    let as_int = c::atoi(numstr)
    let as_float = c::atof(floatstr)
    c::printf("atoi: %d\n", as_int)
    c::printf("atof: %f\n", as_float)

    # abs
    let neg = -99
    let pos = c::abs(neg)
    c::printf("abs(-99): %d\n", pos)

    # rand / srand  (seeded so its reproducible)
    c::srand(42)
    let r1 = c::rand()
    let r2 = c::rand()
    c::printf("rand (seed 42): %d %d\n", r1, r2)

    # getenv
    let home = c::getenv("HOME")
    let shell = c::getenv("SHELL")
    c::printf("HOME=%s\n", home)
    c::printf("SHELL=%s\n", shell)

    # malloc / free  (danger zone, intentionally)
    # just allocate and free, dont do anything wild with it
    let ptr = c::malloc(64)
    c::printf("malloc returned non-null: %d\n", ptr)   # prints address as int, fine
    c::free(ptr)
    c::puts("malloc/free: survived")
}

function test_string() {
    echo "--- string.h ---"

    let a = "Hello"
    let b = "World"
    let c = "Hello"

    # strlen
    let len = c::strlen(a)
    c::printf("strlen(Hello): %d\n", len)

    # strcmp
    let eq = c::strcmp(a, c)
    let ne = c::strcmp(a, b)
    c::printf("strcmp(Hello,Hello): %d\n", eq)   # should be 0
    c::printf("strcmp(Hello,World): %d\n", ne)   # nonzero

    # strcat  (risky without a buffer, lets see what happens)
    # c::strcat(a, b)   # commented out, would corrupt stack. good test of your safety story later

    # strchr  (find first occurrence of char)
    let found = c::strchr(b, 111)   # 'o' = 111
    c::printf("strchr(World, o): %s\n", found)   # should print "orld"

    # strstr
    let haystack = "the quick brown fox"
    let needle = "brown"
    let match = c::strstr(haystack, needle)
    c::printf("strstr result: %s\n", match)   # should print "brown fox"

    # toupper / tolower  (technically ctype.h but close enough)
    let upper = c::toupper(97)   # 'a' -> 'A'
    let lower = c::tolower(65)   # 'A' -> 'a'
    c::printf("toupper(a): %c\n", upper)
    c::printf("tolower(A): %c\n", lower)
}

function test_math() {
    echo "--- math.h ---"

    let x = 2.0
    let y = 9.0
    let angle = 1.0   # radians

    let sq = c::sqrt(y)
    let pw = c::pow(x, 10.0)
    let lg = c::log(x)
    let l2 = c::log2(y)
    let sn = c::sin(angle)
    let cs = c::cos(angle)
    let fl = c::floor(3.9)
    let cl = c::ceil(3.1)
    let ro = c::round(3.5)
    let ab = c::fabs(-7.7)

    c::printf("sqrt(9): %f\n", sq)
    c::printf("pow(2,10): %f\n", pw)
    c::printf("log(2): %f\n", lg)
    c::printf("log2(9): %f\n", l2)
    c::printf("sin(1): %f\n", sn)
    c::printf("cos(1): %f\n", cs)
    c::printf("floor(3.9): %f\n", fl)
    c::printf("ceil(3.1): %f\n", cl)
    c::printf("round(3.5): %f\n", ro)
    c::printf("fabs(-7.7): %f\n", ab)
}

function test_time() {
    echo "--- time.h ---"

    let t = c::time(0)   # passing NULL as 0, depends on your FFI
    c::printf("time(NULL): %ld\n", t)

    # clock
    let clk = c::clock()
    c::printf("clock(): %ld\n", clk)
}

function test_ctype() {
    echo "--- ctype.h ---"

    let digit_char = 53    # '5'
    let alpha_char = 65    # 'A'
    let space_char = 32    # ' '
    let lower_char = 122   # 'z'

    c::printf("isdigit(5): %d\n",  c::isdigit(digit_char))
    c::printf("isalpha(A): %d\n",  c::isalpha(alpha_char))
    c::printf("isspace( ): %d\n",  c::isspace(space_char))
    c::printf("isupper(A): %d\n",  c::isupper(alpha_char))
    c::printf("islower(z): %d\n",  c::islower(lower_char))
    c::printf("isalnum(5): %d\n",  c::isalnum(digit_char))
}

function test_file_io() {
    echo "--- file io (stdio.h) ---"

    # write a temp file via shell, then read it back with C
    echo "line one" > /tmp/alsh_ctest.txt
    echo "line two" >> /tmp/alsh_ctest.txt

    let fp = c::fopen("/tmp/alsh_ctest.txt", "r")

    if ($fp == 0) {
        c::puts("fopen failed!")
        return
    }

    c::puts("fopen: ok")

    # fgetc loop would need your loop + int handling
    # just fclose for now to test the round trip
    let result = c::fclose(fp)
    c::printf("fclose result: %d\n", result)   # 0 = success

    # remove the temp file
    let removed = c::remove("/tmp/alsh_ctest.txt")
    c::printf("remove result: %d\n", removed)   # 0 = success
}

function run_all_cstdlib_tests() {
    c::puts("=== ALSH C stdlib stress test ===")

    test_stdio()
    test_stdlib()
    test_string()
    test_math()
    test_time()
    test_ctype()
    test_file_io()

    c::puts("=== done ===")
    return 0
}
